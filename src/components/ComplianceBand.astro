---
import type { Lang } from '../i18n/index';
import { useTranslations } from '../i18n/index';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const privacyHref = `/${lang}/privacy`;
---

<section class="compliance-band reveal">
  <div class="compliance-inner section-inner">
    <div class="compliance-content">
      <div class="compliance-icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
      </div>
      <div class="compliance-text">
        <h2 class="compliance-heading">{t('compliance.heading')}</h2>
        <p class="compliance-body">{t('compliance.body')} <a href={privacyHref} class="compliance-link">{t('footer.privacy')}</a></p>
      </div>
    </div>
    <span class="compliance-badge eyebrow">{t('compliance.badge')}</span>
  </div>
</section>

<style>
  .compliance-band {
    background: var(--color-navy-mid);
    border-left: 4px solid var(--color-gold);
    padding: 2rem 0;
  }
  .compliance-inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .compliance-content {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    flex: 1;
    min-width: 0;
  }
  .compliance-icon {
    color: var(--color-gold);
    flex-shrink: 0;
    margin-top: 2px;
  }
  .compliance-heading {
    font-family: var(--font-eyebrow);
    font-weight: 700;
    font-size: clamp(0.8rem, 2vw, 0.95rem);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-white);
    margin-bottom: 0.5rem;
  }
  .compliance-body {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.65;
    font-family: ui-monospace, 'Cascadia Code', monospace;
    font-size: 0.8rem;
  }
  .compliance-link {
    color: var(--color-gold);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .compliance-badge {
    flex-shrink: 0;
    border: 1px solid var(--color-border-gold);
    padding: 0.3rem 0.75rem;
    font-size: 0.6rem;
    border-radius: 2px;
    color: var(--color-gold);
    white-space: nowrap;
    align-self: flex-start;
  }
  @media (max-width: 640px) {
    .compliance-badge { display: none; }
    .compliance-inner { gap: 1rem; }
  }
</style>
