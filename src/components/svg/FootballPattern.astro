---
interface Props {
  opacity?: number;
  id?: string;
}
const { opacity = 0.07, id = 'fp' } = Astro.props;
---
<svg xmlns="http://www.w3.org/2000/svg" width="0" height="0" style="position:absolute">
  <defs>
    <pattern id={id} width="90" height="104" patternUnits="userSpaceOnUse">
      <!-- Central hexagon -->
      <polygon
        points="45,6 78,24 78,60 45,78 12,60 12,24"
        fill="none"
        stroke={`rgba(201,168,76,${opacity})`}
        stroke-width="1"
      />
      <!-- Offset lower row -->
      <polygon
        points="90,58 90,94 57,112 24,94 24,58 57,40"
        fill="none"
        stroke={`rgba(201,168,76,${opacity})`}
        stroke-width="1"
      />
      <!-- Pentagon top-left corner continuation -->
      <polygon
        points="0,58 0,94 -33,112 -33,58"
        fill="none"
        stroke={`rgba(201,168,76,${opacity})`}
        stroke-width="1"
      />
    </pattern>
  </defs>
</svg>
