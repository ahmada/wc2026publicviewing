# Email (server-side only)
RESEND_API_KEY=
BREVO_API_KEY=           # optional — only needed if EMAIL_PROVIDER=brevo
NOTIFICATION_EMAIL=      # receives every registration — comma-separated for multiple recipients
EMAIL_PROVIDER=resend    # resend | brevo

# Cloudflare Turnstile (server-side only)
TURNSTILE_SECRET_KEY=

# Google Sheets CRM (server-side only)
GOOGLE_SHEETS_WEBHOOK_URL=   # Apps Script Web App URL (see setup guide)
GOOGLE_SHEETS_SECRET=        # Shared secret — min 32 chars: openssl rand -hex 16
GOOGLE_SHEETS_URL=           # Direct URL to the Google Sheet (shown in notification emails)

# Public (exposed to client via import.meta.env)
PUBLIC_TURNSTILE_SITE_KEY=
PUBLIC_WHATSAPP_NUMBER=  # international format without +, e.g. 601116004096
